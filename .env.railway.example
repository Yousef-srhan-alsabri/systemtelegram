# Railway production variables
# Add these in Railway → Service → Variables. Do not commit real values.

SECRET_KEY=replace-with-long-random-secret
SESSION_ENCRYPTION_KEYS=keep-the-same-key-from-your-current-env
DATABASE_URL=${{Postgres.DATABASE_URL}}

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

FLASK_ENV=production
APP_TIMEZONE=Asia/Aden
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true

MAX_TELEGRAM_ACCOUNTS=50
MESSAGE_DELAY_MIN_SECONDS=20
MESSAGE_DELAY_MAX_SECONDS=30
DEFAULT_BATCH_SIZE=30
MAX_TARGETS_PER_ACCOUNT_TASK=500
QR_LOGIN_TIMEOUT_SECONDS=300

SEARCH_DEFAULT_MAX_RESULTS=250
SEARCH_MAX_RESULTS=1000
SEARCH_SAUDI_THRESHOLD=25
SEARCH_SCOPE_DEFAULT=global_plus_joined
SEARCH_INCLUDE_PUBLIC_MESSAGES=true
SEARCH_GLOBAL_LIMIT=100

JOIN_MAX_ITEMS_PER_JOB=10
JOIN_DELAY_MIN_SECONDS=15
JOIN_DELAY_MAX_SECONDS=30
JOIN_SCAN_MESSAGE_LIMIT=1000
JOIN_CONTINUE_BATCHES=false
JOIN_BATCH_PAUSE_SECONDS=300
JOIN_MAX_BATCHES_PER_RUN=5
JOIN_RESUME_AFTER_FLOODWAIT=true
JOIN_MAX_FLOODWAIT_SLEEP_SECONDS=3600
JOIN_DYNAMIC_MONITOR_SECONDS=60

MAX_UPLOAD_MB=20
ALLOW_BACKUP_RESTORE=false
SCHEDULER_INTERVAL_SECONDS=60
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=180
